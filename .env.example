# TrustLens API Keys
# Copy this file to .env and fill in your actual API keys.

# Google Safe Browsing API Key
# Get yours at: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFE_BROWSING_API_KEY="YOUR_GOOGLE_SAFE_BROWSING_KEY_HERE"

# Google Gemini AI API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_AI_STUDIO_KEY_HERE"

# VirusTotal API Key (free: 4 req/min, 500/day)
# Get yours at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY="YOUR_VIRUSTOTAL_API_KEY_HERE"

# Groq API Key (free: 30 req/min, runs Llama 3.3 70B)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"
